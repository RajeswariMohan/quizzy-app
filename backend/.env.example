# Server
PORT=3000

# PostgreSQL (use 5433 when running docker compose -f docker-compose.test.yml)
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=quizzy
DATABASE_PASSWORD=quizzy
DATABASE_NAME=quizzy

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6380

# JWT (use a long random secret in production)
JWT_SECRET=change-me-to-a-secure-random-string
JWT_EXPIRES_IN=1d

# Super Admin default tenant (Test School seed UUID)
DEFAULT_SCHOOL_ID=11111111-1111-1111-1111-111111111111
