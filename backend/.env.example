# Server
PORT=3000

# PostgreSQL — set DATABASE_URL or individual vars below (URL takes precedence)
#
# Production (Neon): use POOLED URL for the API, DIRECT URL for migrations only.
# DATABASE_URL=postgresql://USER:PASS@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=verify-full&connect_timeout=10
# DATABASE_URL_DIRECT=postgresql://USER:PASS@ep-xxx.REGION.aws.neon.tech/neondb?sslmode=verify-full&connect_timeout=10
# DATABASE_POOL_MAX=10
# DATABASE_CONNECT_TIMEOUT_MS=10000
# DATABASE_IDLE_TIMEOUT_MS=30000
#
# Local Docker:
# DATABASE_URL=postgresql://quizzy:quizzy@localhost:5433/quizzy
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=quizzy
DATABASE_PASSWORD=quizzy
DATABASE_NAME=quizzy

# Redis (BullMQ) — set REDIS_URL or individual vars below (URL takes precedence)
# REDIS_URL=redis://localhost:6380
REDIS_HOST=localhost
REDIS_PORT=6380

# JWT (use a long random secret in production)
JWT_SECRET=change-me-to-a-secure-random-string
JWT_EXPIRES_IN=1d

# Super Admin: optional default school scope when no X-School-Ids header is sent.
# After db:reset:superadmin, leave unset or set to an existing school UUID.
# DEFAULT_SCHOOL_ID=

# Platform tenant for student signups whose school is not yet onboarded
UNLISTED_SCHOOL_ID=77777777-7777-7777-7777-777777777777
