{
  "name": "quizzy-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Quizzy multi-tenant quiz portal API",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/src/main.js",
    "test": "jest --config jest.config.js",
    "test:unit": "jest --config jest.config.js",
    "test:coverage": "jest --config jest.config.js --coverage",
    "test:e2e": "jest --config test/jest-e2e.json --runInBand",
    "test:all": "bash scripts/test-setup.sh",
    "test:ci": "npm run build && npm run test:all",
    "issue-token": "tsx scripts/issue-token.ts",
    "smoke-test": "bash scripts/smoke-test.sh",
    "db:migrate:sessions": "bash scripts/apply-migration-007.sh",
    "db:migrate:feedback": "bash scripts/apply-migration-008.sh",
    "db:migrate:subjects": "bash scripts/apply-migration-009.sh",
    "db:migrate:passwords": "bash scripts/apply-migration-010.sh",
    "db:migrate:audience": "bash scripts/apply-migration-011.sh",
    "db:migrate:all": "bash scripts/db-migrate-all.sh",
    "db:migrate:node": "node scripts/migrate-node.mjs"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.34.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.22.3",
    "typescript": "^5.7.0"
  }
}
